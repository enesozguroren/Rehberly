{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/Auth/{**catch-all}"
        }
      },
      "profile-route": {
        "ClusterId": "profile-cluster",
        "Match": {
          "Path": "/api/Profile/{**catch-all}"
        }
      },
      "route-service-route": {
        "ClusterId": "route-cluster",
        "Match": {
          "Path": "/api/Route/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://auth-service:8080"
          }
        }
      },
      "profile-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://profile-service:8080"
          }
        }
      },
      "route-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://route-service:8080"
          }
        }
      }
    }
  }
}